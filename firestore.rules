rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Lock down everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    match /leads/{leadId} {
      // Sales team can read and update leads if they are logged in. (Creation is done via API)
      allow read, update: if request.auth != null;
      // Deny direct client creation (unless required later)
      allow create, delete: if false;
    }

    match /users/{userId} {
      // Any logged-in sales module user can see the agents list, but can only mutate their own profile
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /settings/{document=**} {
      // Sales team can modify scoring weights
      allow read, write: if request.auth != null;
    }
  }
}
