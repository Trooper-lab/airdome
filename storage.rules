rules_version = '2';

// Firebase Storage Security Rules
// Permits public read for generated presentations (renders)
// Permits authenticated users (sales agents) to upload new renders
service firebase.storage {
  match /b/{bucket}/o {
    
    // Renders path
    match /leads/{leadId}/renders/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Default deny for everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
